# Application
APP_ENV=dev
HTTP_ADDR=:8080
LOG_LEVEL=debug

# JWT
JWT_ISSUER=english-anywhere-lab
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_HOUR=720
JWT_SIGN_KEY=change-me-in-production

# Database
DB_DRIVER=sqlite
SQLITE_PATH=./data/app.db
SQLITE_WAL=true
SQLITE_BUSY_TIMEOUT_MS=5000

# Object Storage
FILES_PROVIDER=local
FILES_LOCAL_ROOT=./data/files

# LLM (M2)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SEC=60
LLM_MAX_RETRIES=2
